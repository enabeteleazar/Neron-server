#!/usr/bin/env python3
"""
Client CLI Néron vNext (secure)
- Support API Key (Authorization Bearer)
- Streaming temps réel
- Memory integration
- Health check
"""

import requests
import json
import os

# =========================
# CONFIG
# =========================

NERON_URL = "http://100.90.194.109:8010"
MEMORY_URL = "http://100.90.194.109:8002"

# 🔐 API KEY (env recommandé)
NERON_API_KEY = os.getenv("NERON_API_KEY", "dev-key")


def get_headers():
    return {
        "Authorization": f"Bearer {NERON_API_KEY}",
        "Content-Type": "application/json"
    }


# =========================
# CORE API
# =========================

def health_check():
    try:
        r = requests.get(
            f"{NERON_URL}/health",
            headers=get_headers(),
            timeout=3
qd        )
        return r.status_code == 200
    except:
        return False


def send_message(text, stream=True):
    endpoint = "/input/stream" if stream else "/input"

    try:
        if stream:
            with requests.post(
                f"{NERON_URL}{endpoint}",
                json={"text": text},
                headers=get_headers(),
                stream=True,
                timeout=60
            ) as r:
                r.raise_for_status()

                full_response = ""

                for chunk in r.iter_lines():
                    if chunk:
                        decoded = chunk.decode("utf-8")

                        try:
                            data = json.loads(decoded)
                            token = data.get("token") or data.get("response", "")
                        except:
                            token = decoded

                        print(token, end="", flush=True)
                        full_response += token

                print()
                return full_response

        else:
            r = requests.post(
                f"{NERON_URL}{endpoint}",
                json={"text": text},
                headers=get_headers(),
                timeout=60
            )
            r.raise_for_status()
            return r.json().get("response", "")

    except requests.exceptions.HTTPError as e:
        if e.response is not None and e.response.status_code == 401:
            return "\n[AUTH ERROR] API key invalide"
        return f"\n[HTTP ERROR] {e}"

    except requests.exceptions.Timeout:
        return "\n[TIMEOUT] Néron trop lent"

    except requests.exceptions.ConnectionError:
        return "\n[ERROR] neron-server inaccessible"

    except Exception as e:
        return f"\n[ERROR] {e}"


# =========================
# MEMORY API
# =========================

def get_history(limit=5):
    try:
        r = requests.get(
            f"{MEMORY_URL}/retrieve",
            params={"limit": limit},
            headers=get_headers(),
            timeout=5
        )
        r.raise_for_status()
        return r.json()
    except:
        return []


def search_memory(query):
    try:
        r = requests.get(
            f"{MEMORY_URL}/search",
            params={"query": query},
            headers=get_headers(),
            timeout=5
        )
        r.raise_for_status()
        return r.json()
    except:
        return []


def get_stats():
    try:
        r = requests.get(
            f"{MEMORY_URL}/stats",
            headers=get_headers(),
            timeout=5
        )
        r.raise_for_status()
        return r.json()
    except:
        return None


# =========================
# UI
# =========================

def print_colored(text, color="blue", end="\n"):
    colors = {
        "blue": "\033[0;34m",
        "green": "\033[0;32m",
        "yellow": "\033[1;33m",
        "red": "\033[0;31m",
        "reset": "\033[0m"
    }
    print(f"{colors.get(color, '')}{text}{colors['reset']}", end=end)


# =========================
# MAIN LOOP
# =========================

def main():
    print("=" * 50)
    print("NÉRON CLIENT vNEXT (SECURE)")
    print("=" * 50)

    # Health check
    if health_check():
        print_colored("[OK] neron-server en ligne", "green")
    else:
        print_colored("[KO] serveur indisponible ou API key invalide", "red")

    print("""
Commandes:
  /history        -> 5 dernières conversations
  /search <mot>   -> recherche mémoire
  /stats          -> stats mémoire
  /health         -> état serveur
  /clear          -> clear écran
  /quit           -> quitter
""")

    while True:
        try:
            print_colored("Vous > ", "blue", end="")
            user_input = input().strip()

            if not user_input:
                continue

            # Quit
            if user_input in ["/quit", "/exit"]:
                print("\nBye\n")
                break

            # Clear
            elif user_input == "/clear":
                print("\033[2J\033[H")
                continue

            # Health
            elif user_input == "/health":
                status = health_check()
                print_colored("OK" if status else "KO", "green" if status else "red")
                continue

            # History
            elif user_input == "/history":
                history = get_history()
                print("\n--- Historique ---")
                for item in history:
                    print(f"\n[{item.get('timestamp', 'N/A')}]")
                    print(f"Vous : {item.get('input', '')[:80]}")
                    print(f"Néron: {item.get('response', '')[:80]}")
                print()
                continue

            # Search
            elif user_input.startswith("/search "):
                query = user_input.split(" ", 1)[1]
                results = search_memory(query)

                print(f"\nRésultats pour: {query}")
                if results:
                    for item in results[:3]:
                        print(f"- {item.get('input', '')[:80]}")
                else:
                    print("Aucun résultat")
                print()
                continue

            # Stats
            elif user_input == "/stats":
                stats = get_stats()
                if stats:
                    print("\nStats mémoire:")
                    print(f"  Total: {stats.get('total_entries', 0)}")
                    print(f"  7 jours: {stats.get('recent_entries_7d', 0)}")
                else:
                    print("Erreur récupération stats")
                print()
                continue

            # MESSAGE NORMAL
            print_colored("Néron > ", "yellow", end="")
            send_message(user_input, stream=True)
            print()

        except KeyboardInterrupt:
            print("\nBye\n")
            break
        except Exception as e:
            print(f"\nErreur: {e}\n")


if __name__ == "__main__":
    main()
