neron:
  version: "2.1.0"
  log_level: INFO
  api_key: "changez_moi"

server:
  host: "0.0.0.0"
  port: 8000

llm:
  model: "llama3.2:1b"
  host: "http://localhost:11434"
  timeout: 300
  temperature: 0.7
  max_tokens: 2048

stt:
  model: "base"
  language: "fr"
  timeout: 60
  max_size_mb: 10
  download_root: ""

tts:
  engine: "pyttsx3"
  language: "fr"
  rate: 150
  max_chars: 1000

telegram:
  enabled: false
  bot_token: "VOTRE_BOT_TOKEN_ICI"
  chat_id: "VOTRE_CHAT_ID_ICI"
  notify_on_start: true

watchdog:
  enabled: false
  check_interval: 30
  restart_max_retries: 3
  alert_telegram: true
  bot_token: "VOTRE_WATCHDOG_BOT_TOKEN_ICI"
  chat_id: "VOTRE_CHAT_ID_ICI"
  cpu_alert: 95
  ram_alert: 85
  disk_alert: 90
  cpu_temp_alert: 75

memory:
  db_path: "data/memory.db"
  retention_days: 30

searxng:
  url: "http://localhost:8080"
  timeout: 10.0
  max_results: 5

system:
  watchdog_url: "http://localhost:8003"

logs:
  dir: "logs"
  neron_log: "neron.log"
  watchdog_log: "watchdog.log"
  max_size_mb: 10
  backup_count: 5
