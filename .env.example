# Répertoire d'installation
NERON_DIR=/opt/neron

# ============================================
#  Néron AI v2.0 — Configuration
#  Copiez ce fichier : cp .env.example .env
# ============================================

# --- Telegram @HomeBox_Neron_bot (conversations) ---
TELEGRAM_BOT_TOKEN=votre_token_ici
TELEGRAM_CHAT_ID=votre_chat_id_ici

# --- Telegram @Neron_Watchdog_bot (monitoring) ---
WATCHDOG_BOT_TOKEN=votre_token_ici
WATCHDOG_CHAT_ID=votre_chat_id_ici
WATCHDOG_ENABLED=false

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- STT (Speech-to-Text) ---
WHISPER_MODEL=base
STT_LANGUAGE=fr

# --- API Core ---
NERON_CORE_HTTP=8000

# --- Logs ---
LOG_LEVEL=INFO

# --- Watchdog (optionnel — valeurs par défaut) ---
WATCHDOG_CPU_ALERT=95
WATCHDOG_RAM_ALERT=85
WATCHDOG_DISK_ALERT=90
WATCHDOG_CPU_TEMP_ALERT=75
