# Variables d'environnement pour la sécurité Neron
# Définir ces variables avant de démarrer le serveur

# Clé de chiffrement Fernet (32 bytes URL-safe base64)
export NERON_CIPHER_KEY="CHANGE_THIS_KEY_IN_PRODUCTION_32_BYTES_KEY"

# Hash SHA256 de l'API_KEY (calculé automatiquement lors de la migration)
# export NERON_API_KEY_HASH="..."

# Autres variables optionnelles
# export NERON_API_KEY="your_api_key_here"
# export HA_TOKEN="your_ha_token"
# export TELEGRAM_BOT_TOKEN="your_bot_token"