# modules/neron_llm/.env.example

# Environnement
ENV=production

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=5000

# Ollama Configuration
OLLAMA_HOST=http://neron-ollama:11434
OLLAMA_TIMEOUT=300.0

# Modèle par défaut
DEFAULT_MODEL=llama3.2:1b

# Limites
MAX_TOKENS=2048
TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO
