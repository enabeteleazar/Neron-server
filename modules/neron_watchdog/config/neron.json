{
  "base_url": "http://neron_core",
  "services": [
    {
      "name": "Neron Core",
      "host": "neron_core",
      "port": 8000,
      "health_path": "/health",
      "enabled": true,
      "description": "Orchestrateur central",
      "critical": true,
      "ssl_verify": true
    },
    {
      "name": "Neron STT",
      "host": "neron_stt",
      "port": 8001,
      "health_path": "/health",
      "enabled": true,
      "description": "Speech-to-Text (Whisper)",
      "critical": true,
      "ssl_verify": true
    },
    {
      "name": "Neron Memory",
      "host": "neron_memory",
      "port": 8002,
      "health_path": "/health",
      "enabled": true,
      "description": "Memoire persistante (SQLite)",
      "critical": true,
      "ssl_verify": true
    },
    {
      "name": "Neron TTS",
      "host": "neron_tts",
      "port": 8003,
      "health_path": "/health",
      "enabled": true,
      "description": "Text-to-Speech",
      "critical": false,
      "ssl_verify": true
    },
    {
      "name": "Neron LLM",
      "host": "neron_llm",
      "port": 5000,
      "health_path": "/health",
      "enabled": true,
      "description": "Wrapper Ollama (LLM)",
      "critical": true,
      "ssl_verify": true
    },
    {
      "name": "Neron Ollama",
      "host": "neron_ollama",
      "port": 11434,
      "health_path": "/api/tags",
      "enabled": true,
      "description": "Moteur LLM (Ollama)",
      "critical": true,
      "ssl_verify": true
    },
    {
      "name": "Neron SearXNG",
      "host": "neron_searxng",
      "port": 8080,
      "health_path": "/healthz",
      "enabled": true,
      "description": "Moteur de recherche",
      "critical": false,
      "ssl_verify": true
    },
    {
      "name": "Neron Web Voice",
      "host": "neron_web_voice",
      "port": 8080,
      "health_path": "/api/health",
      "enabled": true,
      "description": "Interface vocale (Node.js)",
      "critical": false,
      "ssl_verify": false,
      "ssl": true
    },
    {
      "name": "Neron Telegram",
      "host": "neron_telegram",
      "port": 8010,
      "health_path": "/health",
      "enabled": true,
      "description": "Bot Telegram",
      "critical": false,
      "ssl_verify": false,
      "ssl": false
    },
    {
      "name": "Neron Watchdog",
      "host": "neron_watchdog",
      "port": 8003,
      "health_path": "/health",
      "enabled": true,
      "description": "Agent de surveillance",
      "critical": true,
      "ssl_verify": false,
      "ssl": false
    },
    {
      "name": "Neron HUD",
      "host": "neron_hud",
      "port": 8080,
      "health_path": "/health",
      "enabled": false,
      "description": "Dashboard JARVIS",
      "critical": false,
      "ssl_verify": false
    }
