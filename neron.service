[Unit]
Description=Néron AI Assistant v2
After=network.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=eleazar
Group=eleazar
WorkingDirectory=/mnt/usb-storage/Neron_AI/modules/neron_core

# Charger le .env
EnvironmentFile=/mnt/usb-storage/Neron_AI/.env

# Lancer via le venv
ExecStart=/mnt/usb-storage/Neron_AI/venv/bin/python3 app.py

# Restart automatique
Restart=always
RestartSec=10
StartLimitIntervalSec=60
StartLimitBurst=3

# Logs
StandardOutput=append:/mnt/usb-storage/Neron_AI/logs/neron_core.log
StandardError=append:/mnt/usb-storage/Neron_AI/logs/neron_core.log

# Timeout
TimeoutStartSec=120
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
